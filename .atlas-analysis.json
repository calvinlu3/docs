  "keyFeatures": [
    "Somatic variant annotation by protein change, genomic change, HGVSg, or HGVSc",
    "Germline variant annotation",
    "Copy number alteration (CNA) and structural variant (fusion) annotation",
    "Therapeutic levels of evidence (Level 1–4, R1–R2) for FDA-approved and investigational therapies",
    "Diagnostic and prognostic implication levels",
    "Cancer gene list with panel coverage flags (MSK-IMPACT, Foundation Medicine, etc.)",
    "Batch annotation for entire sample mutational profiles",
    "Curated gene and variant evidence database",
    "GRCh37 and GRCh38 reference genome support",
    "Integration with Genome Nexus for genomic coordinate annotation",
    "Free public tier and premium API access"
  ],
  "publicApiSurface": [
